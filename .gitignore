# ========================================
# Laravel Default
# ========================================
/.phpunit.cache
/node_modules
/public/build
/public/hot
/public/storage
/storage/*.key
/storage/pail
/vendor

# ========================================
# Environment & Config
# ========================================
.env
.env.backup
.env.production
/auth.json

# ========================================
# Scribe (API Documentation)
# ========================================
/public/vendor/scribe
/resources/views/scribe
/.scribe
/storage/app/private/scribe

# ========================================
# Database
# ========================================
/database/*.sqlite
/database/*.sqlite-journal

# ========================================
# Storage Uploads
# ========================================
/storage/app/public/products/*
!/storage/app/public/products/.gitkeep

# ========================================
# Logs & Cache
# ========================================
*.log
/storage/logs/*
!/storage/logs/.gitkeep

# ========================================
# IDE & Editor
# ========================================
/.fleet
/.idea
/.nova
/.vscode
/.zed
.phpactor.json
.phpunit.result.cache
*.swp
*.swo
*~

# ========================================
# OS Files
# ========================================
.DS_Store
Thumbs.db
desktop.ini
Homestead.json
Homestead.yaml
